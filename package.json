{
    "name": "digital-rawalpindi",
    "version": "1.0.0",
    "description": "DigitalRawalpindi - Multi-Vendor Marketplace",
    "private": true,
    "scripts": {
        "dev": "next dev --no-turbo",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "build:backend": "cd backend && tsc",
        "start:backend": "cd backend && node dist/server.js",
        "dev:backend": "cd backend && nodemon --exec tsx server.ts",
        "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\""
    },
    "dependencies": {
        "axios": "^1.6.0",
        "next": "14.2.5",
        "react": "18.3.0",
        "react-dom": "18.3.0",
        "next-cloudinary": "^6.17.5"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "autoprefixer": "^10.5.2",
        "concurrently": "^10.0.3",
        "postcss": "^8.5.15",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.0.0"
    }
}